# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── Database ────────────────────────────────────────────────────────────────
# Supabase (production): get from Project Settings → Database → Connection string
# Local dev: postgresql://postgres:password@localhost:5432/talentpulse
DATABASE_URL=postgresql://user:password@host:5432/dbname

# pgvector DB — leave blank to reuse DATABASE_URL (same Supabase DB is fine)
# Local dev with separate instance: postgresql://postgres:password@localhost:5433/vectordb
VECTOR_DB_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google AI (free tier) ───────────────────────────────────────────────────
# Get key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
EMBEDDING_PROVIDER=google
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
GOOGLE_CHAT_MODEL=gemini-2.0-flash
ENABLE_LLM_QUESTIONS=true

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated extra origins (e.g. your Netlify URL)
# Local dev: leave blank — localhost:5173/3000 are always allowed
ALLOWED_ORIGINS=
